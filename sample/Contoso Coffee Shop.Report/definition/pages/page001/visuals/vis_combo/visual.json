{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "vis_combo",
  "position": {
    "x": 20,
    "y": 140,
    "z": 1002,
    "height": 350,
    "width": 700,
    "tabOrder": 1002
  },
  "visual": {
    "visualType": "lineClusteredColumnComboChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": { "SourceRef": { "Entity": "DimDate" } },
                  "Property": "Month"
                }
              },
              "queryRef": "DimDate.Month",
              "nativeQueryRef": "Month"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": { "SourceRef": { "Entity": "Contoso Measures" } },
                  "Property": "Total Revenue"
                }
              },
              "queryRef": "Contoso Measures.Total Revenue",
              "nativeQueryRef": "Total Revenue"
            }
          ]
        },
        "Y2": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": { "SourceRef": { "Entity": "Contoso Measures" } },
                  "Property": "Total Orders"
                }
              },
              "queryRef": "Contoso Measures.Total Orders",
              "nativeQueryRef": "Total Orders"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true,
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": { "Value": "'Revenue and Orders by Month'" }
              }
            },
            "show": {
              "expr": {
                "Literal": { "Value": "true" }
              }
            }
          }
        }
      ]
    }
  }
}
